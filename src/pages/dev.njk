          <ul class="dev-shortcut-list">
            <li><a href="/arobase"><kbd>@</kbd> en accès direct</a> (touche en haut à gauche)</li>
            <li><kbd>#</kbd> sur <kbd>Maj</kbd> + <kbd>@</kbd>, ou <kbd>AltGr</kbd> + <kbd>:</kbd> pour les devs</li>
            <li><kbd>^</kbd> sur <kbd>AltGr</kbd> + <kbd>I</kbd> — le caret direct, sans touche morte</li>
            <li><kbd>`</kbd> sur <kbd>AltGr</kbd> + <kbd>L</kbd></li>
            <li><kbd>~</kbd> sur <kbd>AltGr</kbd> + <kbd>N</kbd></li>
