<main id="main-content">
    <section class="hero pb-8">
      <div class="container">
        <h1 class="hero__title">Signaler un bug</h1>
        <p class="hero__subtitle">Aidez-nous à améliorer AZERTY Global en décrivant le problème rencontré.</p>
      </div>
    </section>

    <section class="section pt-0">
      <div class="container container--narrow">

        <form id="bug-form" class="card" enctype="multipart/form-data">
          <!-- Source (app ou web) -->
          <input type="hidden" id="source" name="source" value="web">
          <!-- Honeypot anti-spam -->
          <input type="checkbox" name="botcheck" class="hidden d-none">

          <!-- System Info -->
          <h2 class="mb-6">💻 Informations système</h2>

          <div class="grid-auto-200 gap-4 d-grid">
            <div class="form-group">
              <label for="app-version" class="form-label">Version de l’application</label>
              <input type="text" id="app-version" name="version-application" class="form-input"
                placeholder="Ex: 1.0.0">
            </div>

            <div class="form-group">
              <label for="os" class="form-label form-label--required">Système d’exploitation</label>
              <input type="text" id="os" name="systeme-exploitation" class="form-input"
                placeholder="Ex: Windows 11" required>
            </div>
          </div>

          <div class="form-group mt-4">
            <label for="install-method" class="form-label">Méthode d’installation</label>
            <select id="install-method" name="methode-installation" class="form-select">
              <option value="">Sélectionner...</option>
              <option value="microsoft-store">Microsoft Store</option>
              <option value="installeur">Installeur classique (pilote clavier)</option>
              <option value="inconnu">Je ne sais pas</option>
            </select>
          </div>

          <!-- Bug Details -->
          <h2 class="mb-6 mt-8">🐛 Le bug</h2>

          <div class="form-group">
            <label for="category" class="form-label form-label--required">Catégorie</label>
            <select id="category" name="categorie" class="form-select" required>
              <option value="">Sélectionner...</option>
              <option value="caracteres-incorrects">Caractères incorrects</option>
              <option value="raccourcis-clavier">Raccourcis clavier</option>
              <option value="installation">Installation / Désinstallation</option>
              <option value="clavier-virtuel">Clavier virtuel</option>
              <option value="recherche-caracteres">Recherche de caractères</option>
              <option value="compatibilite-application">Compatibilité avec une application</option>
              <option value="autre">Autre</option>
            </select>
          </div>

          <div class="form-group mt-4">
            <label for="summary" class="form-label form-label--required">Résumé du bug</label>
            <input type="text" id="summary" name="resume" class="form-input"
              placeholder="Ex: Caps Lock produit des chiffres au lieu des symboles sur la rangée numérique" required>
          </div>

          <div class="form-group mt-4">
            <label for="steps" class="form-label">Étapes pour reproduire le bug</label>
            <textarea id="steps" name="etapes-reproduction" class="form-textarea" rows="4"
              placeholder="1. Activer Verr. Maj.&#10;2. Appuyer sur la touche &amp;&#10;3. ..."></textarea>
            <p class="form-hint">Décrivez précisément les actions à effectuer pour observer le bug.</p>
          </div>

          <div class="form-group mt-4">
            <label for="expected" class="form-label">Comportement attendu</label>
            <textarea id="expected" name="comportement-attendu" class="form-textarea" rows="2"
              placeholder="Ex: La touche devrait produire &amp; comme sans Caps Lock"></textarea>
          </div>

          <div class="form-group mt-4">
            <label for="actual" class="form-label form-label--required">Comportement observé</label>
            <textarea id="actual" name="comportement-observe" class="form-textarea" rows="2"
              placeholder="Ex: La touche produit 1 au lieu de &amp;" required></textarea>
          </div>

          <div class="form-group mt-4">
            <label for="app-name" class="form-label">Application concernée (si applicable)</label>
            <input type="text" id="app-name" name="nom-application" class="form-input"
              placeholder="Ex: Word, VS Code, Chrome, Discord...">
          </div>

          <!-- Attachments (envoi par email — Web3Forms gratuit ne supporte pas les uploads) -->
          <h2 class="mb-6 mt-8">📎 Capture d’écran ou vidéo</h2>

          <div class="form-group">
            <p class="form-hint">
              Pour joindre une capture d’écran ou une vidéo, envoyez-la séparément par email à
              <a href="mailto:support@azerty.global">support@azerty.global</a>
              en mentionnant le résumé du bug ci-dessus.
            </p>
          </div>

          <!-- Contact -->
          <h2 class="mb-6 mt-8">📧 Contact (optionnel)</h2>

          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-input" placeholder="votre@email.com">
            <p class="form-hint">Pour vous recontacter si besoin. Jamais partagé.</p>
          </div>

          <!-- Submit -->
          <div class="mt-8">
            <button type="submit" class="btn btn--primary btn--lg w-full">
              <span>🐛</span>
              Envoyer le rapport de bug
            </button>
          </div>

        </form>

        <!-- Alternative Contact -->
        <div class="card text-center mt-6">
          <h4 class="mb-4">Autres moyens de signaler un bug</h4>
          <div class="flex-wrap justify-center gap-4 d-flex">
            <a href="mailto:support@azerty.global" class="btn btn--secondary">
              <span>📧</span>
              Email
            </a>
            <a href="https://discord.gg/nYknqshJz3" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
              <span>💬</span>
              Discord
            </a>
            <a href="https://github.com/AZERTYGlobal/website/issues" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
              <span>🐙</span>
              GitHub Issues
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
