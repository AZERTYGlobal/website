<main id="main-content">
    <section class="hero pb-8">
      <div class="container container--narrow">
        <p class="pilot-eyebrow">Pilote gratuit AZERTY Global</p>
        <h1 class="hero__title">Bilan du pilote</h1>
        <p class="hero__subtitle">
          Un bilan court à J14 ou J28 : adoption, envie de continuer, point positif, blocage principal et citation autorisable.
        </p>
        <div class="hero__actions">
          <a href="/pilote" class="btn btn--secondary btn--lg">Retour au kit pilote</a>
          <a href="/download" class="btn btn--primary btn--lg">Télécharger AZERTY Global</a>
        </div>
      </div>
    </section>

    <section class="section pt-0">
      <div class="container container--narrow">
        <div class="pilot-warning mb-6">
          <strong>Écoles :</strong> ne demandez pas de réponse directe nominative aux élèves mineurs.
          La personne référente agrège les retours utiles et remplit le bilan au nom de la classe, du groupe ou de la salle informatique.
        </div>

        <form id="pilot-report-form" class="card pilot-form-card">
          <input type="checkbox" name="botcheck" class="hidden d-none">

          <fieldset class="form-section-fieldset">
            <legend class="sr-only">Contexte du bilan</legend>
            <h2 class="mb-6">Contexte</h2>

            <div class="pilot-form-grid">
              <div class="form-group">
                <label for="report-role" class="form-label form-label--required">Rôle</label>
                <select id="report-role" name="role-bilan" class="form-select" required>
                  <option value="">Sélectionner...</option>
                  <option value="personne-referente">Personne référente</option>
                  <option value="volontaire">Volontaire</option>
                </select>
              </div>

              <div class="form-group">
                <label for="report-structure" class="form-label form-label--required">Structure ou code pilote</label>
                <input type="text" id="report-structure" name="structure-ou-code" class="form-input" required>
              </div>

              <div class="form-group">
                <label for="report-moment" class="form-label form-label--required">Moment du bilan</label>
                <select id="report-moment" name="moment" class="form-select" required>
                  <option value="">Sélectionner...</option>
                  <option value="j14">J14</option>
                  <option value="j28">J28</option>
                </select>
              </div>

              <div class="form-group">
                <label for="report-score" class="form-label form-label--required">Note de 1 à 10</label>
                <select id="report-score" name="note-1-10" class="form-select" required>
                  <option value="">Sélectionner...</option>
                  <option value="1">1 — Très difficile</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                  <option value="4">4</option>
                  <option value="5">5 — Mitigé</option>
                  <option value="6">6</option>
                  <option value="7">7</option>
                  <option value="8">8</option>
                  <option value="9">9</option>
                  <option value="10">10 — Très convaincant</option>
                </select>
              </div>

              <div class="form-group form-group--full">
                <label for="report-continue" class="form-label form-label--required">Envie de continuer</label>
                <select id="report-continue" name="envie-de-continuer" class="form-select" required>
                  <option value="">Sélectionner...</option>
                  <option value="oui">Oui</option>
                  <option value="non">Non</option>
                  <option value="a-voir">À voir</option>
                </select>
              </div>
            </div>
          </fieldset>

          <fieldset class="form-section-fieldset">
            <legend class="sr-only">Retours qualitatifs</legend>
            <h2 class="mb-6 mt-8">Retours qualitatifs</h2>

            <div class="form-group">
              <label for="report-positive" class="form-label form-label--required">Point positif principal</label>
              <textarea id="report-positive" name="point-positif-principal" class="form-textarea" rows="4" required></textarea>
            </div>

            <div class="form-group mt-4">
              <label for="report-blocker" class="form-label form-label--required">Blocage principal</label>
              <textarea id="report-blocker" name="blocage-principal" class="form-textarea" rows="4" required></textarea>
            </div>

            <div class="pilot-form-grid mt-4">
              <div class="form-group">
                <label for="report-quote" class="form-label form-label--required">Citation autorisable</label>
                <select id="report-quote" name="citation-autorisable" class="form-select" required>
                  <option value="">Sélectionner...</option>
                  <option value="oui-anonyme">Oui, anonymisée</option>
                  <option value="non">Non</option>
                </select>
                <p class="form-hint">Choisir oui permet d'utiliser un extrait anonyme pour présenter le projet.</p>
              </div>

              <div class="form-group">
                <label for="report-email" class="form-label">Email optionnel</label>
                <input type="email" id="report-email" name="email-optionnel" class="form-input" autocomplete="email">
                <p class="form-hint">Uniquement si vous acceptez d'être recontacté.</p>
              </div>
            </div>
          </fieldset>

          <div class="mt-8">
            <button type="submit" class="btn btn--primary btn--lg w-full">
              Envoyer le bilan
            </button>
          </div>
        </form>
      </div>
    </section>

    <section class="section">
      <div class="container container--narrow">
        <div class="pilot-panel text-center">
          <h2>Besoin de prolonger le test ?</h2>
          <p class="text-secondary">
            Le format prévoit une prolongation optionnelle de 2 semaines si le premier bilan montre un intérêt mais demande plus de recul.
          </p>
          <div class="pilot-email-row justify-center">
            <a href="mailto:business@azerty.global" class="btn btn--secondary">business@azerty.global</a>
            <a href="mailto:education@azerty.global" class="btn btn--secondary">education@azerty.global</a>
          </div>
        </div>
      </div>
    </section>
  </main>
