          <div class="pilot-form-grid">
            <div class="form-group">
              <label for="pilot-name" class="form-label form-label--required">Nom</label>
              <input type="text" id="pilot-name" name="nom" class="form-input" autocomplete="name" required>
            </div>

            <div class="form-group">
              <label for="pilot-email" class="form-label form-label--required">Email</label>
              <input type="email" id="pilot-email" name="email" class="form-input" autocomplete="email" required>
            </div>

            <div class="form-group">
              <label for="pilot-structure" class="form-label form-label--required">Structure</label>
              <input type="text" id="pilot-structure" name="structure" class="form-input" autocomplete="organization" required>
            </div>

            <div class="form-group">
              <label for="pilot-profile" class="form-label form-label--required">Profil</label>
              <select id="pilot-profile" name="profil" class="form-select" required>
                <option value="">Sélectionner...</option>
                <option value="ecole">École</option>
                <option value="administration">Administration</option>
                <option value="entreprise">Entreprise</option>
                <option value="autre-organisation">Autre organisation</option>
              </select>
            </div>

            <div class="form-group">
