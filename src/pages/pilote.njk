              <select id="pilot-admin-type" name="type_administration" class="form-select" required disabled>
                <option value="">Sélectionner...</option>
                <option value="collectivite">Collectivité territoriale</option>
                <option value="service-etat">Service de l’État</option>
                <option value="etablissement-public">Établissement public</option>
                <option value="sante-social">Santé ou social</option>
                <option value="autre">Autre</option>
