                <option value="5-10">5 à 10</option>
                <option value="plus-de-10">Plus de 10</option>
                <option value="a-confirmer">À confirmer</option>
              </select>
            </div>

            <div class="form-group">
              <label for="pilot-period" class="form-label form-label--required">Période souhaitée</label>
              <select id="pilot-period" name="periode" class="form-select" required>
                <option value="">Sélectionner...</option>
                <option value="des-que-possible">Dès que possible</option>
                <option value="dans-le-mois">Dans le mois</option>
                <option value="trimestre-prochain">Trimestre prochain</option>
                <option value="a-definir">À définir</option>
