<main id="main-content">
    <!-- Hero -->
    <section class="hero pb-8">
      <div class="container">
        <h1 class="hero__title">Support the project</h1>
        <p class="hero__subtitle">
          AZERTY Global is free, open source, and carried by the AMCF.
        </p>
        <div class="hero__actions hero__actions--home mt-5">
          <a href="https://www.helloasso.com/associations/association-pour-la-modernisation-du-clavier-francais/formulaires/1?lang=en"
             target="_blank" rel="noopener noreferrer"
             data-modal-target="modal-don"
             class="btn btn--primary btn--lg">💰 Donate</a>
          <a href="https://www.helloasso.com/associations/association-pour-la-modernisation-du-clavier-francais/adhesions/adhesion-amcf?lang=en"
             target="_blank" rel="noopener noreferrer"
             data-modal-target="modal-adherer"
             class="btn btn--secondary btn--lg">🤝 Join</a>
        </div>
      </div>
    </section>

    <!-- AMCF Association -->
    <section class="section pt-0">
      <div class="container container--narrow">
        <h2 class="mb-4 text-center" id="amcf">🏢 The AMCF Association</h2>
        <div class="card">
          <p class="section-lead">
            The <strong>Association pour la Modernisation du Clavier Français</strong> (AMCF) — the French keyboard modernization association — is a French nonprofit (association loi 1901) founded in March 2026 in Clermont-Ferrand. It officially maintains the AZERTY Global project.
          </p>
          <p class="mt-4 font-semibold">Its missions:</p>
          <ul class="mt-2 text-secondary leading-loose">
            <li><strong>Develop and distribute</strong> free and open source keyboard layouts</li>
            <li><strong>Raise awareness</strong> among schools, companies and institutions</li>
            <li><strong>Produce educational resources</strong> and guides</li>
            <li><strong>Collaborate with research</strong> — support scientific studies on the benefits of the layout</li>
          </ul>
          <p class="mt-4 text-secondary">
            The association operates in complete <strong>transparency</strong>: every euro received is
            reinvested in the project.
          </p>
        </div>
      </div>
    </section>

    <!-- Why support -->
    <section class="section">
      <div class="container container--narrow">
        <div class="bg-gradient-primary border-primary-1 card">
          <h2 class="mb-4 text-center">❤️ Why support us?</h2>
          <p class="section-lead">
            Since <strong>2017</strong>, AZERTY Global has been developed by one volunteer.
            The software is <strong>free</strong>, <strong>ad-free</strong>, <strong>tracking-free</strong>
            and <strong>open source</strong> under the <a href="/licence">EUPL 1.2</a> license.
          </p>
          <p class="mt-3 section-lead">
            But development, hosting, scientific studies and communication have a cost.
            Every gesture of support — financial or not — helps the project grow and stay independent.
          </p>
        </div>
      </div>
    </section>

    <!-- What your support funds -->
    <section class="section">
      <div class="container">
        <h2 class="mb-4 text-center">🎯 What your support funds</h2>
        <div class="grid-auto-280 gap-4 d-grid">
          <div class="card">
            <h3 class="mb-3">💰 Your donations fund</h3>
            <ul class="text-secondary pl-4 leading-loose">
              <li><strong>Technical tools</strong>: domain names, hosting, development software</li>
              <li><strong>On-the-ground presence</strong>: tech and public events, demo equipment (foldable keyboards with AZERTY Global stickers)</li>
              <li><strong>Communication</strong>: online advertising and partnerships to raise awareness of the project</li>
              <li><strong>Scientific studies</strong>: proving the benefits of the layout (fatigue, speed, ergonomics)</li>
            </ul>
          </div>
          <div class="card">
            <h3 class="mb-3">📢 Your word of mouth helps</h3>
            <ul class="text-secondary pl-4 leading-loose">
              <li>Convince <strong>schools and companies</strong> to try it</li>
              <li>Show institutions that an <strong>alternative exists</strong></li>
              <li>Build a <strong>community</strong> of users helping each other</li>
              <li>Strengthen the project's <strong>credibility</strong> with decision-makers</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Other ways to help -->
    <section class="section">
      <div class="container">
        <h2 class="mb-4 text-center" id="aider">💡 Other ways to help</h2>
        <div class="benefits__grid gap-4">
          <div class="card">
            <div class="card__icon">📣</div>
            <h3 class="card__title">Talk about the project</h3>
            <p class="card__text">
              Word of mouth is our best lever. Tell your colleagues and friends about AZERTY Global, on social media too.
            </p>
            <a href="/presse" class="btn btn--secondary mt-3 w-full">
              Press kit (in French)
            </a>
          </div>
          <div class="card">
            <div class="card__icon">💬</div>
            <h3 class="card__title">Share your feedback</h3>
            <p class="card__text">
              Try the layout and report bugs or suggestions. Your feedback shapes future versions.
            </p>
            <a href="/en/feedback" class="btn btn--secondary mt-3 w-full">
              Feedback &amp; Discord
            </a>
          </div>
          <div class="card">
            <div class="card__icon">🏫</div>
            <h3 class="card__title">Adopt it at your company or school</h3>
            <p class="card__text">
              Deploy AZERTY Global in your organization. We can help you along the way.
            </p>
            <a href="/entreprises" class="btn btn--secondary mt-3 w-full">
              Learn more (in French)
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section">
      <div class="container">
        <h2 class="section__title text-center">User feedback</h2>
        <div id="temoignages-carousel"></div>
      </div>
    </section>

    <!-- Join the team -->
    <section class="section">
      <div class="container">
        <h2 class="mb-4 text-center" id="equipe">🤝 Join the team</h2>
        <p class="text-secondary leading-relaxed text-lg mb-5 text-center">
          AZERTY Global is run by a very small team. To go further,
          we're looking for <strong>motivated volunteers</strong> in these areas:
        </p>
        <div class="benefits__grid gap-4">
          <div class="card">
            <div class="card__icon">🛠</div>
            <h3 class="card__title">Technical co-maintainer</h3>
            <p class="card__text">
              Maintain the website, the online tester and the app.
              Profile: web or fullstack developer, comfortable with Git and GitHub.
            </p>
            <a href="mailto:amcf@azerty.global?subject=Volunteering%20%E2%80%94%20Technical%20co-maintainer"
              class="btn btn--secondary mt-3 w-full">
              Contact us
            </a>
          </div>
          <div class="card">
            <div class="card__icon">📣</div>
            <h3 class="card__title">Communication &amp; social media</h3>
            <p class="card__text">
              Run social media accounts, write articles, reach out to media
              and French-speaking communities.
            </p>
            <a href="mailto:amcf@azerty.global?subject=Volunteering%20%E2%80%94%20Communication"
              class="btn btn--secondary mt-3 w-full">
              Contact us
            </a>
          </div>
          <div class="card">
            <div class="card__icon">🏛</div>
            <h3 class="card__title">Institutional relations</h3>
            <p class="card__text">
              Support outreach to administrations, schools
              and AFNOR.
            </p>
            <a href="mailto:amcf@azerty.global?subject=Volunteering%20%E2%80%94%20Institutional%20relations"
              class="btn btn--secondary mt-3 w-full">
              Contact us
            </a>
          </div>
          <div class="card">
            <div class="card__icon">🎨</div>
            <h3 class="card__title">Design &amp; UX</h3>
            <p class="card__text">
              Create communication visuals and improve the user
              experience of the website and tools.
            </p>
            <a href="mailto:amcf@azerty.global?subject=Volunteering%20%E2%80%94%20Design%20%26%20UX"
              class="btn btn--secondary mt-3 w-full">
              Contact us
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="final-cta">
      <div class="container">
        <h3 class="mb-4 text-2xl">Every gesture counts</h3>
        <p class="mb-6 text-white">
          Help the AMCF make the French keyboard simpler to use every day.
        </p>
        <div class="flex-wrap justify-center gap-4 d-flex">
          <a href="https://www.helloasso.com/associations/association-pour-la-modernisation-du-clavier-francais/formulaires/1?lang=en"
             target="_blank" rel="noopener noreferrer"
             data-modal-target="modal-don"
             class="bg-white text-indigo btn btn--lg">
            Donate
          </a>
          <a href="https://discord.gg/nYknqshJz3" target="_blank" rel="noopener noreferrer" class="btn btn--lg text-white bg-black-30 backdrop-blur border-white-20">
            Join the Discord
          </a>
        </div>
      </div>
    </section>

