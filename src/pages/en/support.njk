    <div id="modal-adherer" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-adherer-title" aria-hidden="true">
      <div class="modal__overlay"></div>
      <div class="modal__content">
        <button type="button" class="modal__close" aria-label="Close">×</button>
        <h2 id="modal-adherer-title" class="sr-only">Join the AMCF</h2>
        <div class="modal__body">
          <iframe
            data-src="https://www.helloasso.com/associations/association-pour-la-modernisation-du-clavier-francais/adhesions/adhesion-amcf/widget?lang=en"
            title="Join the AMCF"
            loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </main>
