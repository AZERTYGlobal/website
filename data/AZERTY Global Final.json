  "standard": "ISO/ANSI",
  "country": "France",
  "description": "Final version of the AZERTY Global keyboard layout, created by Antoine OLIVIER",
  "philosophy": {
    "ambition": "Become the new French AZERTY standard across all operating systems, replacing AZERTY AFNOR within 5 years",
    "target_audience": [
        "French-speaking general public and writers needing proper French typography (goal: millions of users)",
        "Developers needing easy access to programming symbols",
        "Anyone typing in European languages (foreign residents in France, French speakers learning languages)"
    ],
    "design_principles": [
        "Minimal changes from classic Windows AZERTY: fix flaws without revolution",
        "Smart Caps Lock that only affects letters, with easy access to Гү, ГҲ, ГҮ, ГҖ",
        "Programming symbols on AltGr home row ({ } [ ] | \\)",
        "Full support for French and European languages",
        "Intuitive placement: no stickers needed, easy to remember",
        "Sparse AltGr layer to limit Ctrl+Alt conflicts; rare characters via dead keys"
    ],
    "not_goals": [
        "Radical ergonomic optimization (this is not a BГ©po or Dvorak)",
        "Compatibility with the AFNOR NF Z71-300 standard"
    ]
},
  "changes_from_traditional_azerty": {
    "Period and semicolon swapped on B08": "Period is more frequent than semicolon",
    "Smart Caps Lock: only affects letters": "Easy access to Гү, ГҲ, ГҮ, ГҖ without Shift",
    "Programming symbols on AltGr home row": "{ } [ ] | \\ ` ~ easily accessible for developers",
    "@ and # on E00": "Copies Mac AZERTY, @ much more accessible for emails",
    "Г№ and % moved to place acute and grave accents on C11": "Direct access to very common European accents",
    "Вө, В§ and ВӨ become dead keys for Greek alphabet, punctuation and currency": "Access to many more characters via these dead keys"
},
  "conventions": {
    "caps_lock_behavior": "Caps Lock only affects keys that produce letters (accented or not)",
    "caps": "If absent, use the base value (Caps lock does not affect symbols)",
    "caps_shift": "If absent, use the shift value (Caps lock does not affect symbols)",
    "caps_alt_gr": "If absent, use the alt_gr value (Caps Lock does not affect symbols)",
    "caps_shift_alt_gr": "If absent, use the shift_alt_gr value (Caps Lock does not affect symbols)",
    "null_meaning": "No output for this key combination"
},
